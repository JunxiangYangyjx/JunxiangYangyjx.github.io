---
import { profile } from '../data/profile';
import { withBase } from '../utils/links';

const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-soft">
  <div class="site-container grid gap-8 py-10 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <p class="text-lg font-semibold text-ink">{profile.name}</p>
      <p class="mt-3 max-w-md leading-7 text-muted">个人学术、项目与生活展示网站。内容以中文为主，Research 和个人介绍区域提供局部 CN/EN 切换。</p>
    </div>

    <div>
      <p class="font-semibold text-ink">快速入口</p>
      <div class="mt-3 grid gap-2 text-sm text-muted">
        <a href={withBase('/research/')}>Study & Research</a>
        <a href={withBase('/research/projects/')}>Projects</a>
        <a href={withBase('/life/')}>My Life</a>
        <a href={withBase(profile.cvUrl)}>CV 下载</a>
      </div>
    </div>

    <div>
      <p class="font-semibold text-ink">Contact</p>
      <div class="mt-3 grid gap-2 text-sm text-muted">
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
        {profile.links.map((link) => <a href={link.href}>{link.label}</a>)}
      </div>
    </div>
  </div>
  <div class="border-t border-line py-4">
    <p class="site-container text-sm text-muted">© {year} {profile.name}. Built with Astro.</p>
  </div>
</footer>
