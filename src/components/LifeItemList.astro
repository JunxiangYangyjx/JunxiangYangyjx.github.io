---
import type { LifeItem } from '../data/life';

interface Props {
  items: LifeItem[];
}

const { items } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2">
  {
    items.map((item) => (
      <article class="card">
        <p class="text-sm font-semibold text-accent">{item.category}</p>
        <h3 class="mt-2 text-xl font-semibold text-ink">{item.title}</h3>
        <p class="mt-3 leading-7 text-muted">{item.summary}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {item.tags.map((tag) => (
            <span class="rounded-md bg-soft px-2.5 py-1 text-xs font-medium text-muted">{tag}</span>
          ))}
        </div>
        {item.externalLink && (
          <a class="mt-4 inline-flex text-sm font-semibold text-accent" href={item.externalLink}>
            外部链接
          </a>
        )}
      </article>
    ))
  }
</div>
