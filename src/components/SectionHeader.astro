---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 text-2xl font-semibold text-ink sm:text-3xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-8 text-muted">{description}</p>}
</div>
