---
import type { ResearchProject } from '../data/research';
import { withBase } from '../utils/links';

interface Props {
  project: ResearchProject;
  bilingual?: boolean;
  scope?: string;
}

const { project, bilingual = false, scope = 'research' } = Astro.props;
const detailHref = project.hasDetail ? withBase(`/research/projects/${project.slug}/`) : undefined;
---

<article class="card flex h-full flex-col gap-4">
  {
    project.images?.[0] && (
      <img
        class="aspect-[16/9] w-full rounded-md border border-line bg-soft object-contain p-2"
        src={withBase(project.images[0].src)}
        alt={project.images[0].alt}
        loading="lazy"
      />
    )
  }

  <div class="flex flex-wrap items-center gap-2 text-xs font-semibold text-muted">
    <span>{project.year}</span>
    <span aria-hidden="true">/</span>
    <span>{project.status}</span>
  </div>

  {
    bilingual ? (
      <>
        <div data-lang-panel={scope} data-lang="cn">
          <p class="text-sm font-semibold text-accent">{project.categoryZh}</p>
          <h3 class="mt-2 text-xl font-semibold text-ink">{project.titleZh}</h3>
          <p class="mt-3 leading-7 text-muted">{project.summaryZh}</p>
          <p class="mt-3 text-sm text-ink">
            <span class="font-semibold">职责：</span>
            {project.roleZh}
          </p>
        </div>
        <div data-lang-panel={scope} data-lang="en" hidden>
          <p class="text-sm font-semibold text-accent">{project.categoryEn}</p>
          <h3 class="mt-2 text-xl font-semibold text-ink">{project.titleEn}</h3>
          <p class="mt-3 leading-7 text-muted">{project.summaryEn}</p>
          <p class="mt-3 text-sm text-ink">
            <span class="font-semibold">Role: </span>
            {project.roleEn}
          </p>
        </div>
      </>
    ) : (
      <div>
        <p class="text-sm font-semibold text-accent">{project.categoryZh}</p>
        <h3 class="mt-2 text-xl font-semibold text-ink">{project.titleZh}</h3>
        <p class="mt-3 leading-7 text-muted">{project.summaryZh}</p>
      </div>
    )
  }

  <div class="mt-auto flex flex-wrap gap-2 pt-2">
    {project.keywords.map((keyword) => <span class="rounded-md bg-soft px-2.5 py-1 text-xs font-medium text-muted">{keyword}</span>)}
  </div>

  {
    detailHref && (
      <a class="mt-1 text-sm font-semibold text-accent hover:text-accent-strong" href={detailHref}>
        查看详情
      </a>
    )
  }
</article>
