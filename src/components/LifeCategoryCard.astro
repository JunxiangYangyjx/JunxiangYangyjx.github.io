---
import { withBase } from '../utils/links';

interface Props {
  category: {
    slug: string;
    title: string;
    summary: string;
    accent: string;
  };
}

const { category } = Astro.props;
---

<a class="card group block h-full transition hover:border-accent" href={withBase(`/life/${category.slug}/`)}>
  <p class="text-sm font-semibold text-accent">{category.accent}</p>
  <h3 class="mt-3 text-xl font-semibold text-ink group-hover:text-accent">{category.title}</h3>
  <p class="mt-3 leading-7 text-muted">{category.summary}</p>
</a>
