---
import type { LifeItem } from '../data/life';
import { withBase } from '../utils/links';

interface Props {
  item: LifeItem;
}

const { item } = Astro.props;
const tracks = item.tracks ?? [];
---

<section class="min-h-[calc(100vh-4rem)] border-b border-line bg-gradient-to-b from-white via-[#f7fbfd] to-white">
  <div class="site-container flex min-h-[calc(100vh-4rem)] flex-col justify-center gap-10 py-10 lg:grid lg:grid-cols-[minmax(0,0.95fr)_minmax(420px,1.05fr)] lg:items-center">
    <div>
      <a class="text-sm font-semibold text-accent" href={withBase('/life/')}>返回 My Life</a>
      <p class="mt-8 text-xs font-semibold uppercase tracking-widest text-accent">Spotify Playlist</p>
      <h1 class="mt-4 text-5xl font-semibold leading-tight text-ink sm:text-6xl lg:text-7xl">{item.title}</h1>
      <p class="mt-6 max-w-xl text-lg leading-8 text-muted">{item.summary}</p>
      <div class="mt-6 flex flex-wrap gap-2">
        {item.tags.map((tag) => (
          <span class="rounded-md bg-white px-3 py-1.5 text-xs font-semibold text-muted shadow-sm ring-1 ring-line">{tag}</span>
        ))}
      </div>
      <div class="mt-8 flex flex-wrap gap-3">
        {item.spotifyUrl && (
          <a class="btn-primary" href={item.spotifyUrl} target="_blank" rel="noreferrer">在 Spotify 打开</a>
        )}
        <a class="btn-secondary" href="#playlist-tracks">往下看歌曲</a>
      </div>
    </div>

    <div class="rounded-2xl border border-line bg-white p-4 shadow-xl shadow-slate-200/70 sm:p-6">
      <div class="grid gap-5 sm:grid-cols-[150px_minmax(0,1fr)] sm:items-center">
        {item.coverImage && (
          <img
            class="mx-auto aspect-square w-full max-w-48 rounded-xl border border-line bg-soft object-cover shadow-sm sm:max-w-none"
            src={item.coverImage}
            alt={item.coverAlt ?? item.title}
            loading="lazy"
          />
        )}
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-accent">Now on Spotify</p>
          <h2 class="mt-3 text-3xl font-semibold text-ink">{item.title}</h2>
          <p class="mt-3 leading-7 text-muted">Spotify 原生播放器保留为紧凑播放入口；主要视觉由这个页面自定义控制。</p>
        </div>
      </div>

      {item.spotifyEmbedUrl && (
        <div class="mt-6 overflow-hidden rounded-xl border border-line bg-soft">
          <iframe
            class="block h-[152px] w-full"
            src={item.spotifyEmbedUrl}
            title={`Spotify playlist: ${item.title}`}
            width="100%"
            height="352"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
          />
        </div>
      )}
    </div>
  </div>
</section>

<section id="playlist-tracks" class="site-section bg-white">
  <div class="site-container">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">Songs</p>
        <h2 class="mt-3 text-3xl font-semibold text-ink">歌单里的歌</h2>
        <p class="mt-3 max-w-2xl leading-7 text-muted">这里先放当前播放器里能确认的曲目；后续你给我想展示的歌名，我可以继续补全并加备注。</p>
      </div>
      {item.spotifyUrl && (
        <a class="btn-secondary" href={item.spotifyUrl} target="_blank" rel="noreferrer">查看完整歌单</a>
      )}
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {tracks.map((track) => (
        <article class="card flex min-h-56 flex-col">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-accent">{track.artist}</p>
              <h3 class="mt-2 text-2xl font-semibold text-ink">{track.title}</h3>
            </div>
            {track.duration && <span class="rounded-md bg-soft px-2.5 py-1 text-xs font-semibold text-muted">{track.duration}</span>}
          </div>
          {track.note && <p class="mt-5 leading-7 text-muted">{track.note}</p>}
          {track.tags && (
            <div class="mt-auto flex flex-wrap gap-2 pt-6">
              {track.tags.map((tag) => (
                <span class="rounded-md bg-soft px-2.5 py-1 text-xs font-medium text-muted">{tag}</span>
              ))}
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
